{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "通过 npm 启动",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"], // 这里的 "dev" 对应 package.json 中的 script 名称
      "skipFiles": ["<node_internals>/**"],
      
    }
  ]
}